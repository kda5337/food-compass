# 농수산물 관련 API 키 값
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# 생필품 관련 API 키 값
PRICE_GOKR_SERVICE_KEY=

# Upstage API Key
UPSTAGE_API_KEY=

# Langfuse관련 key 값 (선택 — 비어있으면 트레이싱 없이 조용히 넘어감)
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=

# Supabase (PostgreSQL 호스팅) — price_cache Fallback DB
# SUPABASE_URL    : 대시보드 > Project Settings > API > Project URL
# SUPABASE_KEY    : 대시보드 > Project Settings > API > service_role (secret)
# DATABASE_URL    : 대시보드 > Project Settings > Database > Connection string (URI)
#                   → psycopg2 직접 연결 시 사용 (app/tools/price_cache.py)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# [2026-07-14] CodeRabbit은 CLI(API 키) 대신 GitHub App으로 연동 — 여기 등록할 키 없음