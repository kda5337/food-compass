# 농수산물 관련 API 키 값
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# 생필품 관련 API 키 값
PRICE_GOKR_SERVICE_KEY=

# Upstage API Key
UPSTAGE_API_KEY=

# Langfuse관련 key 값
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Supabase (PostgreSQL 호스팅) — price_cache Fallback DB
# SUPABASE_URL    : 대시보드 > Project Settings > API > Project URL
# SUPABASE_KEY    : 대시보드 > Project Settings > API > service_role (secret)
# DATABASE_URL    : 대시보드 > Project Settings > Database > Connection string (URI)
#                   → psycopg2 직접 연결 시 사용 (app/tools/price_cache.py)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# CodeRabbit CLI — CI 단계 AI 코드 리뷰용
# 로컬 .env에는 참고용으로만 두고, GitHub Actions에서 쓰려면 repo Secrets에도 별도 등록 필요
CODERABBIT_API_KEY=